# 企业微信机器人凭据（从企业微信管理后台 -> 应用管理 -> 智能机器人获取）
WECOM_BOT_ID=填写你的_bot_id
WECOM_BOT_SECRET=填写你的_secret

# 调用 Hermes 的超时时间（默认 5 分钟，单位：毫秒）
HERMES_TIMEOUT_MS=300000

# 用户会话在内存中的有效期（默认 24 小时，单位：毫秒）
SESSION_TTL_MS=86400000

# 必填：允许调用机器人的企业微信用户 ID（逗号分隔）
ALLOWED_USERIDS=zhangsan,lisi

# 是否启用 Hermes --yolo（默认关闭，建议仅在受控环境开启）
HERMES_ENABLE_YOLO=false

# 允许上传给企业微信的媒体根目录（相对 bridge.mjs 所在目录）
MEDIA_BASE_DIR=./media

# 允许上传媒体文件的最大体积（默认 10MB，单位：字节）
MAX_MEDIA_FILE_SIZE_BYTES=10485760

{
  "name": "wecom-bot-hermes",
  "version": "1.0.0",
  "description": "WeCom (Enterprise WeChat) -> Hermes Agent local bridge. Enables full tool access (terminal, file, browser) via WeChat messages.",
  "type": "module",
  "main": "bridge.mjs",
  "scripts": {
    "start": "node bridge.mjs",
    "dev": "node --inspect bridge.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs"
  },
  "keywords": [
    "wecom",
    "enterprise-wechat",
    "hermes",
    "ai-agent",
    "bridge",
    "bot"
  ],
  "author": "MoringstarsH",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@wecom/aibot-node-sdk": "file:./vendor/@wecom/aibot-node-sdk"
  }
}
